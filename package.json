{
  "name": "zillow-mcp",
  "version": "0.10.6",
  "mcpName": "io.github.chrischall/zillow-mcp",
  "description": "Zillow MCP server for Claude — developed and maintained by AI (Claude Code)",
  "author": "Claude Code (AI) <https://www.anthropic.com/claude>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrischall/zillow-mcp.git"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "ai",
    "zillow",
    "real-estate",
    "property",
    "zestimate",
    "housing"
  ],
  "type": "module",
  "bin": {
    "zillow-mcp": "dist/bundle.js"
  },
  "files": [
    "dist",
    ".claude-plugin",
    ".mcp.json",
    "server.json",
    "SKILL.md"
  ],
  "scripts": {
    "build": "tsc --noEmit && npm run bundle",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --banner:js='import { createRequire as __createRequire } from \"module\"; const require = __createRequire(import.meta.url);' --outfile=dist/bundle.js",
    "dev": "node dist/bundle.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@chrischall/mcp-utils": "^0.12.0",
    "@chrischall/realty-core": "^0.4.1",
    "@fetchproxy/server": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.7"
  }
}
